{
  "name": "superstore-analytics",
  "description": "This is a starter template for building Fabric Apps - Analytics web apps. Clone this repo locally and follow the steps below to get started.",
  "license": "MIT",
  "author": "Microsoft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "rayfin env --framework vite",
    "prebuild": "rayfin env --framework vite",
    "dev": "vite",
    "build": "npx fabric-app-data generate -o src/fabric.generated.ts && tsc -b --noCheck && vite build",
    "build:fabric": "npx fabric-app-data generate -o src/fabric.generated.ts && tsc -b --noCheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fabric": "node scripts/open-fabric-portal.mjs"
  },
  "dependencies": {
    "@microsoft/fabric-app-data": "1.0.0",
    "@microsoft/fabric-app-data-embed-client": "1.0.0",
    "@microsoft/fabric-app-data-proxy": "1.0.0",
    "@microsoft/fabric-datagrid": "1.0.0",
    "@microsoft/fabric-visuals": "1.0.0",
    "@microsoft/fabric-visuals-core": "1.0.0",
    "@microsoft/rayfin-auth-provider-fabric": "^1.32.0",
    "@microsoft/rayfin-client": "^1.32.0",
    "@microsoft/rayfin-core": "^1.32.0",
    "@microsoft/rayfin-data": "^1.32.0",
    "@microsoft/rayfin-lib": "^1.32.0",
    "@tailwindcss/vite": "^4.2.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.2",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@microsoft/fabric-app-data-cli": "1.0.0",
    "@microsoft/fabric-app-data-cli-proxy": "1.0.0",
    "@microsoft/rayfin-cli": "^1.23.0",
    "@microsoft/rayfin-mcp": "^1.30.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-license": "^3.7.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.2.6",
    "vitest": "^3.2.2"
  }
}
