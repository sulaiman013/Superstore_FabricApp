# Rayfin auto-generates the real .env.local from rayfin/.env on `rayfin up` / `rayfin env`.
# These are the variables a deployed Fabric App reads. Never commit real values.
VITE_RAYFIN_API_URL=https://<your-app-backend>.pbidedicated.windows.net/.../
VITE_RAYFIN_PUBLISHABLE_KEY=pk-xxxxxxxxxxxxxxxxxxxx
VITE_FABRIC_ITEM_ID=<YOUR_APP_BACKEND_ID>
VITE_FABRIC_WORKSPACE_ID=<YOUR_WORKSPACE_ID>
VITE_FABRIC_TENANT_ID=<YOUR_TENANT_ID>
VITE_FABRIC_PORTAL_URL=https://app.fabric.microsoft.com
